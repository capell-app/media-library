{
    "name": "capell-app/media-library",
    "description": "Curator-backed media foundation for Capell CMS: unified media field, media-health reporting, and Spatie-to-Curator migration.",
    "keywords": [
        "capell",
        "media",
        "curator",
        "filament"
    ],
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "capell.app26@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "awcodes/filament-curator": "^4.0|^5.0",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/core": "^4.0 || 4.x-dev"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\MediaLibrary\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\MediaLibrary\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\MediaLibrary\\MediaLibraryServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "filament/*": true,
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "type": "library",
    "homepage": "https://github.com/capell-app/media-library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/media-library"
    }
}
